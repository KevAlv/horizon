<script
  src="{{ 'benefits-ingredients.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<benefits-ingredients
  class="benefits-ingredients section section--page-width color-{{ section.settings.color_scheme }} spacing-style"
  style="{% render 'spacing-style', settings: section.settings %}"
  {{ section.shopify_attributes }}
>
  {%- comment -%}
    Benefits data built from variant metafields.
    In a generic PDP, it uses the current `product` object.
    You can also select a specific product in the section settings.
  {%- endcomment -%}
  {%- assign pdp_product = section.settings.product | default: product | default: all_products['jade-crystal-facial-roller'] -%}

  <script type="application/json" id="benefits-data-{{ section.id }}">
  {
    "default": {
      "benefits": {{ pdp_product.metafields.custom.benefits.value | json }},
      "ingredients": {{ pdp_product.metafields.custom.ingredients.value | json }},
      "how_to_use": {{ pdp_product.metafields.custom.how_to_use.value | json }}
    }
    {% for variant in pdp_product.variants %}
      ,"{{ variant.id }}": {
        "benefits": {{ variant.metafields.custom.benefits.value | json }},
        "ingredients": {{ variant.metafields.custom.ingredients.value | json }},
        "how_to_use": {{ variant.metafields.custom.how_to_use.value | json }}
      }
    {% endfor %}
  }
  </script>

  <div class="benefits-ingredients__inner">
    {% if section.settings.heading != blank %}
      <h2 class="benefits-ingredients__heading">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <div
      role="tablist"
      aria-label="Product information"
      class="benefits-ingredients__tablist"
    >
      <button
        role="tab"
        id="tab-benefits-{{ section.id }}"
        aria-selected="true"
        aria-controls="panel-benefits-{{ section.id }}"
        tabindex="0"
        class="benefits-ingredients__tab"
        data-tab="benefits"
      >
        Benefits
      </button>
      <button
        role="tab"
        id="tab-ingredients-{{ section.id }}"
        aria-selected="false"
        aria-controls="panel-ingredients-{{ section.id }}"
        tabindex="-1"
        class="benefits-ingredients__tab"
        data-tab="ingredients"
      >
        Ingredients
      </button>
      <button
        role="tab"
        id="tab-how-to-use-{{ section.id }}"
        aria-selected="false"
        aria-controls="panel-how-to-use-{{ section.id }}"
        tabindex="-1"
        class="benefits-ingredients__tab"
        data-tab="how_to_use"
      >
        How to Use
      </button>
    </div>

    <div aria-live="polite" class="benefits-ingredients__panels">
      <div
        role="tabpanel"
        id="panel-benefits-{{ section.id }}"
        aria-labelledby="tab-benefits-{{ section.id }}"
        tabindex="0"
        class="benefits-ingredients__panel"
      ></div>
      <div
        role="tabpanel"
        id="panel-ingredients-{{ section.id }}"
        aria-labelledby="tab-ingredients-{{ section.id }}"
        tabindex="0"
        class="benefits-ingredients__panel"
        hidden
      ></div>
      <div
        role="tabpanel"
        id="panel-how-to-use-{{ section.id }}"
        aria-labelledby="tab-how-to-use-{{ section.id }}"
        tabindex="0"
        class="benefits-ingredients__panel"
        hidden
      ></div>
    </div>
  </div>
</benefits-ingredients>

{% stylesheet %}
  .benefits-ingredients {
    display: block;
  }

  .benefits-ingredients__inner {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-margin);
  }

  .benefits-ingredients__heading {
    margin-block-end: var(--margin-md);
    font-size: var(--font-h3--size);
  }

  /* Tab list */
  .benefits-ingredients__tablist {
    display: flex;
    gap: 0;
    border-bottom: 1px solid rgb(var(--color-border-rgb));
    margin-block-end: var(--margin-lg);
  }

  .benefits-ingredients__tab {
    position: relative;
    padding: var(--padding-sm) var(--padding-md);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    font-size: var(--font-paragraph--size);
    color: rgb(var(--color-foreground-rgb) / var(--opacity-subdued-text));
    transition: color 0.2s ease, border-color 0.2s ease;
    margin-bottom: -1px;
    white-space: nowrap;
  }

  .benefits-ingredients__tab:hover {
    color: var(--color-foreground);
  }

  .benefits-ingredients__tab[aria-selected='true'] {
    color: var(--color-foreground);
    border-bottom-color: var(--color-foreground);
    font-weight: var(--font-weight-semibold);
  }

  .benefits-ingredients__tab:focus-visible {
    outline: 2px solid var(--color-foreground);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* Panels */
  .benefits-ingredients__panel {
    animation: tab-fade-in 0.2s ease;
    line-height: var(--line-height-body);
  }

  .benefits-ingredients__panel ul {
    padding-inline-start: 1.25em;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--gap-sm);
  }

  .benefits-ingredients__panel li {
    line-height: var(--line-height-body);
  }

  @keyframes tab-fade-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile */
  @media screen and (max-width: 749px) {
    .benefits-ingredients__tab {
      padding: var(--padding-xs) var(--padding-sm);
      font-size: var(--font-paragraph-small--size);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Benefits & Ingredients",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Benefits & Ingredients"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product",
      "info": "Optional. Falls back to current product context."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Benefits & Ingredients",
      "category": "Product"
    }
  ]
}
{% endschema %}
